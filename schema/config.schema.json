{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "machineName": {
      "type": "string",
      "minLength": 1
    },
    "logLevel": {
      "default": "info",
      "type": "string",
      "enum": [
        "trace",
        "debug",
        "info",
        "warn",
        "error"
      ]
    },
    "intervalSeconds": {
      "default": 60,
      "type": "number",
      "exclusiveMinimum": 0
    },
    "reminderIntervalMinutes": {
      "default": 30,
      "type": "number",
      "exclusiveMinimum": 0
    },
    "database": {
      "default": {
        "path": "/var/lib/baba/baba.db"
      },
      "type": "object",
      "properties": {
        "path": {
          "default": "/var/lib/baba/baba.db",
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "path"
      ],
      "additionalProperties": false
    },
    "checks": {
      "default": {
        "cpu": {
          "enabled": true,
          "usageThresholdPercent": 90,
          "consecutiveBreaches": 3
        },
        "load": {
          "enabled": true,
          "threshold": 8,
          "consecutiveBreaches": 3
        },
        "memory": {
          "enabled": true,
          "usageThresholdPercent": 90,
          "consecutiveBreaches": 3
        },
        "disk": {
          "enabled": true,
          "usageThresholdPercent": 90,
          "volumes": [
            "/"
          ]
        },
        "temperature": {
          "enabled": false,
          "cpuThresholdCelsius": 85,
          "gpuThresholdCelsius": 85,
          "consecutiveBreaches": 3
        },
        "gpu": {
          "enabled": false,
          "vramThresholdPercent": 90,
          "consecutiveBreaches": 3
        }
      },
      "type": "object",
      "properties": {
        "cpu": {
          "default": {
            "enabled": true,
            "usageThresholdPercent": 90,
            "consecutiveBreaches": 3
          },
          "type": "object",
          "properties": {
            "enabled": {
              "default": true,
              "type": "boolean"
            },
            "usageThresholdPercent": {
              "default": 90,
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "consecutiveBreaches": {
              "default": 3,
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "enabled",
            "usageThresholdPercent",
            "consecutiveBreaches"
          ],
          "additionalProperties": false
        },
        "load": {
          "default": {
            "enabled": true,
            "threshold": 8,
            "consecutiveBreaches": 3
          },
          "type": "object",
          "properties": {
            "enabled": {
              "default": true,
              "type": "boolean"
            },
            "threshold": {
              "default": 8,
              "type": "number",
              "exclusiveMinimum": 0
            },
            "consecutiveBreaches": {
              "default": 3,
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "enabled",
            "threshold",
            "consecutiveBreaches"
          ],
          "additionalProperties": false
        },
        "memory": {
          "default": {
            "enabled": true,
            "usageThresholdPercent": 90,
            "consecutiveBreaches": 3
          },
          "type": "object",
          "properties": {
            "enabled": {
              "default": true,
              "type": "boolean"
            },
            "usageThresholdPercent": {
              "default": 90,
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "consecutiveBreaches": {
              "default": 3,
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "enabled",
            "usageThresholdPercent",
            "consecutiveBreaches"
          ],
          "additionalProperties": false
        },
        "disk": {
          "default": {
            "enabled": true,
            "usageThresholdPercent": 90,
            "volumes": [
              "/"
            ]
          },
          "type": "object",
          "properties": {
            "enabled": {
              "default": true,
              "type": "boolean"
            },
            "usageThresholdPercent": {
              "default": 90,
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "volumes": {
              "default": [
                "/"
              ],
              "minItems": 1,
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "enabled",
            "usageThresholdPercent",
            "volumes"
          ],
          "additionalProperties": false
        },
        "temperature": {
          "default": {
            "enabled": false,
            "cpuThresholdCelsius": 85,
            "gpuThresholdCelsius": 85,
            "consecutiveBreaches": 3
          },
          "type": "object",
          "properties": {
            "enabled": {
              "default": false,
              "type": "boolean"
            },
            "cpuThresholdCelsius": {
              "default": 85,
              "type": "number",
              "exclusiveMinimum": 0
            },
            "gpuThresholdCelsius": {
              "default": 85,
              "type": "number",
              "exclusiveMinimum": 0
            },
            "consecutiveBreaches": {
              "default": 3,
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "enabled",
            "cpuThresholdCelsius",
            "gpuThresholdCelsius",
            "consecutiveBreaches"
          ],
          "additionalProperties": false
        },
        "gpu": {
          "default": {
            "enabled": false,
            "vramThresholdPercent": 90,
            "consecutiveBreaches": 3
          },
          "type": "object",
          "properties": {
            "enabled": {
              "default": false,
              "type": "boolean"
            },
            "vramThresholdPercent": {
              "default": 90,
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "consecutiveBreaches": {
              "default": 3,
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "enabled",
            "vramThresholdPercent",
            "consecutiveBreaches"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "cpu",
        "load",
        "memory",
        "disk",
        "temperature",
        "gpu"
      ],
      "additionalProperties": false
    },
    "updates": {
      "default": {
        "notifyEnabled": true
      },
      "type": "object",
      "properties": {
        "notifyEnabled": {
          "default": true,
          "type": "boolean"
        }
      },
      "required": [
        "notifyEnabled"
      ],
      "additionalProperties": false
    },
    "notifiers": {
      "minItems": 1,
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "discord"
              },
              "webhookUrl": {
                "type": "string",
                "format": "uri",
                "description": "Webhook URL from Discord → Channel Settings → Integrations → Webhooks."
              }
            },
            "required": [
              "type",
              "webhookUrl"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "telegram"
              },
              "botToken": {
                "type": "string",
                "minLength": 1,
                "description": "Token from @BotFather on Telegram."
              },
              "chatId": {
                "type": "string",
                "minLength": 1,
                "description": "Target chat. Use a user ID, a group ID (prefixed with `-`), or `@channelname`."
              }
            },
            "required": [
              "type",
              "botToken",
              "chatId"
            ],
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "required": [
    "machineName",
    "logLevel",
    "intervalSeconds",
    "reminderIntervalMinutes",
    "database",
    "checks",
    "updates",
    "notifiers"
  ],
  "additionalProperties": false
}
