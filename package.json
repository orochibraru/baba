{
	"name": "@orochibraru/baba",
	"module": "index.ts",
	"type": "module",
	"version": "1.0.7",
	"private": true,
	"scripts": {
		"dev": "bun run --hot ./src/index.ts start",
		"build": "bun run ./scripts/build.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"gen:schema": "bun run scripts/generate-schema.ts",
		"gen:docs": "bun run scripts/generate-docs.ts && biome format --write config.example.json",
		"gen": "bun run gen:schema && bun run gen:docs",
		"prepare": "husky",
		"check": "tsc --noEmit --project tsconfig.json",
		"release": "semantic-release"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@loglayer/transport-pino": "^3.2.0",
		"@types/bun": "^1.3.14",
		"@types/node": "^26.0.1",
		"commander": "^15.0.0",
		"husky": "^9.1.7",
		"loglayer": "^9.3.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"semantic-release": "^25.0.5",
		"systeminformation": "^5.31.11",
		"testcontainers": "^12.0.4",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
